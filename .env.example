# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# (Reminder: rotate any key that has ever been committed in plaintext.)

# ============================================================================
# OBSERVABILITY BACKEND
# ============================================================================
# Default is LOCAL PHOENIX. Leave TRACE_BACKEND unset (or =phoenix) for local.
# Set TRACE_BACKEND=ax to ship the same OpenInference spans to Arize AX instead
# (the enterprise upgrade path; then ARIZE_* below must be filled in).
TRACE_BACKEND=phoenix
PHOENIX_ENDPOINT=http://localhost:6006
ARIZE_PROJECT_NAME=strands-agentcore-cookbook-local

# ============================================================================
# BEDROCK KNOWLEDGE BASE (the partner-native retrieval primitive, Step 2)
# ============================================================================
# REQUIRED for the REAL KB tool. Get KB_ID from the Bedrock console ->
# Knowledge bases. KB_DATA_SOURCE_ID is only needed for ingest/sync helper
# scripts; the retrieve() call itself needs only KB_ID.
KB_ID=
KB_DATA_SOURCE_ID=

# Set MOCK_KB=true to bypass Bedrock and serve canned docs/ markdown so you can
# demo the full trace + eval + feedback loop even if KB provisioning stalls.
# Real Bedrock KB is the DEFAULT (MOCK_KB unset or false).
MOCK_KB=false

# ============================================================================
# AWS / BEDROCK
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Only for SSO / STS / federated logins:
AWS_SESSION_TOKEN=
# For TRACK B (AgentCore), use a region where AgentCore is available, e.g. us-west-2.

# ============================================================================
# LLM-AS-JUDGE (Step 5 evals + Step 6 feedback loop)
# ============================================================================
# Used by src/evaluators/llm_judge.py and src/feedback_loop.py. If unset, those
# scripts fall back to a deterministic offline stub judge (clearly labeled).
OPENAI_API_KEY=

# ============================================================================
# ENTERPRISE UPGRADE PATH: Arize AX (only needed when TRACE_BACKEND=ax)
# ============================================================================
# Arize AX -> Space Settings -> copy Space ID + API Key.
ARIZE_SPACE_ID=
ARIZE_API_KEY=
